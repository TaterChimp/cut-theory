# Demonstration of completeness: least upper bound (supremum)
def sup(cuts: list[DedekindCut]) -> DedekindCut:
    """
    Supremum of a set of cuts: lower set is union of all lower sets.
    Assumes the set is bounded above.
    """
    def sup_lower_pred(q: Fraction) -> bool:
        return any(c.is_in_lower(q) for c in cuts)
    return DedekindCut(sup_lower_pred)

# Utility function to approximate a Dedekind cut numerically
def approximate(c: DedekindCut, precision: int = 10) -> float:
    """
    Approximate the real number represented by the cut to given decimal precision.
    Uses binary search between bounds.
    """
    low = Fraction(-100, 1)  # Arbitrary large negative
    high = Fraction(100, 1)   # Arbitrary large positive
    for _ in range(precision * 2):  # Refine bounds
        mid = (low + high) / 2
        if c.is_in_lower(mid):
            low = mid
        else:
            high = mid
    return float(high)

