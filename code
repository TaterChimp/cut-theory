# Basic Cut class for integer-based cuts
class Cut:
    """
    Represents a cut operation: m cut n, producing (pieces, size) tuple.
    m: number of wholes (positive integer)
    n: number of cuts (non-negative integer)
    """
    def __init__(self, m: int, n: int):
        if n < 0 or m <= 0:
            raise ValueError("m must be positive, n must be non-negative")
        self.m = m
        self.n = n
        self.pieces = m * (n + 1)
        self.size = Fraction(1, n + 1) if n >= 0 else Fraction(1)  # Handles n=0

    def __repr__(self):
        return f"({self.pieces}, {self.size})"

    def __str__(self):
        return self.__repr__()

    def add(self, other: 'Cut') -> 'Cut':
        """
        Add two cuts if their sizes match.
        """
        if self.size != other.size:
            raise ValueError("Sizes must match for addition")
        return Cut(self.m + other.m, self.n)

    def scale(self, k: int) -> 'Cut':
        """
        Scale the cut by an integer factor k.
        """
        if k <= 0:
            raise ValueError("Scaling factor k must be positive")
        return Cut(k * self.m, self.n)

